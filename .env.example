# Production database. Use Supabase, Neon, Railway, RDS, or any managed Postgres.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/ai_sales_copilot?schema=public"
# Direct (non-pooled) connection used by Prisma migrations. On Neon/Vercel this is POSTGRES_URL_NON_POOLING.
POSTGRES_URL_NON_POOLING="postgresql://USER:PASSWORD@HOST:5432/ai_sales_copilot?schema=public"

# Selects the shared seeded workspace that new users join.
DEMO_WORKSPACE_ID=""

# Auth.js (NextAuth v5). Generate AUTH_SECRET with: npx auth secret
AUTH_SECRET=""
# Public base URL used for auth callbacks and password-reset links.
AUTH_URL="http://localhost:3000"

# Resend email (password reset). Without these the reset link is logged to the server console.
RESEND_API_KEY=""
EMAIL_FROM="AI Sales Copilot <onboarding@resend.dev>"

# Future integrations. Keep secrets server-side only.
OPENAI_API_KEY=""
TELEGRAM_BOT_TOKEN=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_APP_URL="http://localhost:3000"

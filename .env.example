# Production database. Use Supabase, Neon, Railway, RDS, or any managed Postgres.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/ai_sales_copilot?schema=public"
# Direct (non-pooled) connection used by Prisma migrations.
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST:5432/ai_sales_copilot?schema=public"

# Selects the shared seeded workspace that new users join.
DEMO_WORKSPACE_ID=""

# Auth.js (NextAuth v5). Generate AUTH_SECRET with: npx auth secret
AUTH_SECRET=""
# Public base URL used for auth callbacks and password-reset links.
AUTH_URL="http://localhost:3000"

# SMTP email (password reset). For Gmail use an App Password (not your normal password).
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="you@gmail.com"
SMTP_PASSWORD="your-16-char-app-password"
SMTP_FROM="AI Sales Copilot <you@gmail.com>"

# Future integrations. Keep secrets server-side only.
OPENAI_API_KEY=""
TELEGRAM_BOT_TOKEN=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_APP_URL="http://localhost:3000"
